generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums replaced with String for SQLite compatibility.
// Valid values documented in comments — enforced at app layer via Zod.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          String    @default("USER")    // USER | OWNER | MANAGER | ADMIN
  disabled      Boolean   @default(false)
  phone         String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  properties    Property[]
  inquiries     Inquiry[]
  verifications AdminVerification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Property {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   // FLAT | HOUSE | VILLA | OFFICE | SHOP
  listingType String   // RENT | SALE
  status      String   @default("PENDING")  // PENDING | ACTIVE | INACTIVE | REJECTED

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  // Location — flatNumber is NEVER returned in public or Manager API responses
  address    String
  building   String
  flatNumber String?
  locality   String
  latitude   Float?
  longitude  Float?

  // Details
  bedrooms    Int?
  bathrooms   Int?
  areaSqft    Float
  floor       Int?
  totalFloors Int?
  furnished   String   @default("UNFURNISHED")  // FURNISHED | SEMI_FURNISHED | UNFURNISHED
  amenities   String   @default("[]")           // JSON array stored as string

  // Pricing
  price            Float
  deposit          Float?
  rentNegotiable   Boolean @default(false)
  lockInMonths     Int?
  lockInNegotiable Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  images        PropertyImage[]
  priceHistory  PriceHistory[]
  inquiries     Inquiry[]
  verifications AdminVerification[]

  @@index([status, listingType, type])
  @@index([ownerId])
  @@index([locality])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  url        String
  s3Key      String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model PriceHistory {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  price      Float
  recordedAt DateTime @default(now())
  source     String   @default("LISTING")  // LISTING | ADMIN_IMPORT
}

model Inquiry {
  id                String   @id @default(cuid())
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id])
  seekerId          String
  seeker            User     @relation(fields: [seekerId], references: [id])
  status            String   @default("PENDING")  // PENDING | PAID | COMPLETED
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([propertyId, seekerId])
}

model AdminVerification {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])
  action     String   // APPROVED | REJECTED
  notes      String?
  createdAt  DateTime @default(now())
}
