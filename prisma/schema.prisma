generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String              @id @default(cuid())
  name          String?
  email         String              @unique
  password      String?
  role          String              @default("USER")
  disabled      Boolean             @default(false)
  phone         String?
  emailVerified DateTime?
  image         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  accounts      Account[]
  verifications AdminVerification[]
  inquiries     Inquiry[]
  properties    Property[]
  sessions      Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Property {
  id               String              @id @default(cuid())
  title            String
  description      String
  type             String
  listingType      String
  status           String              @default("PENDING")
  ownerId          String
  address          String
  building         String
  flatNumber       String?
  locality         String
  latitude         Float?
  longitude        Float?
  bedrooms         Int?
  bathrooms        Int?
  areaSqft         Float
  floor            Int?
  totalFloors      Int?
  furnished        String              @default("UNFURNISHED")
  amenities        String              @default("[]")
  price            Float
  deposit          Float?
  rentNegotiable   Boolean             @default(false)
  lockInMonths     Int?
  lockInNegotiable Boolean             @default(false)
  views            Int                 @default(0)
  activatedAt      DateTime?
  closedAt         DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  verifications    AdminVerification[]
  inquiries        Inquiry[]
  priceHistory     PriceHistory[]
  owner            User                @relation(fields: [ownerId], references: [id])
  images           PropertyImage[]

  @@index([status, listingType, type])
  @@index([ownerId])
  @@index([locality])
}

model PropertyImage {
  id         String   @id @default(cuid())
  propertyId String
  url        String
  s3Key      String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model PriceHistory {
  id         String   @id @default(cuid())
  propertyId String
  price      Float
  recordedAt DateTime @default(now())
  source     String   @default("LISTING")
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id                String   @id @default(cuid())
  propertyId        String
  seekerId          String
  status            String   @default("PENDING")
  phone             String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  property          Property @relation(fields: [propertyId], references: [id])
  seeker            User     @relation(fields: [seekerId], references: [id])

  @@unique([propertyId, seekerId])
}

model AdminVerification {
  id         String   @id @default(cuid())
  propertyId String
  adminId    String
  action     String
  notes      String?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])
}
