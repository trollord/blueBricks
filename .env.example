# ── Database ────────────────────────────────────────────────────────────────
# Postgres connection string (local or Neon). schema=public for local.
DATABASE_URL="postgresql://user:password@localhost:5432/bluebricks?schema=public"

# ── Auth (NextAuth v5) ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32  (use the same value for both keys)
NEXTAUTH_SECRET="your-32-char-random-secret"
AUTH_SECRET="your-32-char-random-secret"
# Base URL of the app — http://localhost:3000 locally, production URL when deployed
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# ── Google OAuth (optional — enables "Continue with Google") ────────────────
# Console: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <base-url>/api/auth/callback/google
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# ── Google Maps (optional — maps on listing pages) ──────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="AIzaSyXXXXXXXX"

# ── AWS S3 (optional — property image uploads) ──────────────────────────────
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID="AKIAXXXXXXXX"
AWS_SECRET_ACCESS_KEY="xxxxxxxx"
AWS_S3_BUCKET_NAME="your-bucket-name"
NEXT_PUBLIC_AWS_S3_BUCKET_URL="https://your-bucket-name.s3.ap-south-1.amazonaws.com"

# ── Resend (required for emails: OTP verification, password reset, lead alerts)
# Dashboard: https://resend.com — verify your sending domain first
RESEND_API_KEY="re_xxxxxxxx"

# ── Razorpay (optional — advisory fee payments) ─────────────────────────────
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxx"
